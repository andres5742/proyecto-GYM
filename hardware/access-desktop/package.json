{
  "name": "sport-gym-acceso",
  "version": "1.0.0",
  "description": "App de escritorio Sport Gym — pantalla /acceso + lector + F2/F3 torniquete",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist:install": "electron-builder --win nsis --ia32",
    "dist": "electron-builder --win portable --ia32",
    "dist:x64": "electron-builder --win portable --x64"
  },
  "author": "Sport Gym",
  "license": "UNLICENSED",
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.sportgym.acceso",
    "productName": "Sport Gym Acceso",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "../turnstile-gateway",
        "to": "turnstile-gateway",
        "filter": [
          "**/*",
          "!**/.lector-tarjeta.pid"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["ia32"]
        }
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Sport Gym Acceso",
      "uninstallDisplayName": "Sport Gym Acceso",
      "artifactName": "SportGym-Acceso-Setup-${version}-win32.${ext}"
    },
    "portable": {
      "artifactName": "SportGym-Acceso-${version}-win32.exe"
    },
    "files": [
      "main.js",
      "preload.js",
      "config.json",
      "config.example.json",
      "package.json"
    ]
  }
}
