# Sport Gym — torniquete PC ACCESO (probado en sitio)
TURNSTILE_GATE_MODE=serial
TURNSTILE_GATE_PROTOCOL=atp-acceso
TURNSTILE_GATE_PORT=COM3
TURNSTILE_GATE_BAUD=19200
# Bloqueo fisico confirmado en gym: d (estable en ATP viejo)
TURNSTILE_LOCK_CHARS=d
TURNSTILE_RELOCK_CHARS=dd
TURNSTILE_UNLOCK_CHAR=a
# App ATP antigua: tras abrir con 'a' enviaba una segunda letra (normalmente 'h').
TURNSTILE_UNLOCK_FOLLOW_CHAR=h
TURNSTILE_UNLOCK_MS=3500
