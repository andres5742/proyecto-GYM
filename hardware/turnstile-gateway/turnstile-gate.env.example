# Protocolo ATP-ACCESO 4.0 (analizado del .exe del gym):
#   COM3, 19200 baud para rele/luces — un solo caracter ASCII.
#   Bloquear: d   Liberar (bienvenida): h   (l,m,n segun dias en ATP; h = OK)
# El lector de tarjeta sigue en 9600 (SERIAL_BAUD en iniciar-lector-tarjeta.bat).

TURNSTILE_GATE_MODE=serial
TURNSTILE_GATE_PROTOCOL=atp-acceso
TURNSTILE_GATE_PORT=COM3
TURNSTILE_GATE_BAUD=19200
# BLOQUEO fisico probado en gym: b, c, d, e. Desbloqueo: a (y otras que no bloquean).
TURNSTILE_LOCK_CHAR=d
TURNSTILE_UNLOCK_CHAR=a
TURNSTILE_UNLOCK_MS=8000

# Alternativa hex generica (otros torniquetes):
# TURNSTILE_GATE_PROTOCOL=
# TURNSTILE_LOCK_BYTES=
# TURNSTILE_UNLOCK_BYTES=
