# Protocolo ATP-ACCESO 4.0 (COM3 @ 19200, un caracter ASCII por comando).
# Lector tarjeta: 9600 baud (SERIAL_BAUD en iniciar-lector-tarjeta.bat).

TURNSTILE_GATE_MODE=serial
TURNSTILE_GATE_PROTOCOL=atp-acceso
TURNSTILE_GATE_PORT=COM3
TURNSTILE_GATE_BAUD=19200
# Bloqueo probado en gym: d (estable en ATP viejo)
TURNSTILE_LOCK_CHARS=d
TURNSTILE_UNLOCK_CHAR=a
TURNSTILE_UNLOCK_MS=8000

# Una sola letra de bloqueo (alternativa a LOCK_CHARS):
# TURNSTILE_LOCK_CHAR=d

# Otros torniquetes (hex):
# TURNSTILE_GATE_PROTOCOL=
# TURNSTILE_LOCK_BYTES=
# TURNSTILE_UNLOCK_BYTES=
