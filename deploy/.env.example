# Copiar a deploy/.env en el servidor (no subir a git con secretos reales)

# PostgreSQL
POSTGRES_DB=gym_db
POSTGRES_USER=gym_user
POSTGRES_PASSWORD=cambiar_password_seguro

# Backend
SERVER_PORT=8080
JWT_SECRET=cambiar-clave-minimo-32-caracteres-aleatorios
JWT_EXPIRATION_MS=86400000
# Misma clave en backend Y en el build del frontend (torniquete /acceso)
ACCESS_DEVICE_KEY=cambiar-clave-torniquete-segura

# URLs públicas (para CORS y build Angular)
GYM_PUBLIC_URL=https://gym.tudominio.com
GYM_API_PUBLIC_URL=https://api.gym.tudominio.com
CORS_ORIGINS=https://gym.tudominio.com

# Build frontend (se pasan al docker build)
API_URL=https://api.gym.tudominio.com/api
UPLOADS_BASE_URL=https://api.gym.tudominio.com
