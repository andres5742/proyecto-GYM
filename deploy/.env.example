# Copiar a deploy/.env en el VPS (NO subir deploy/.env a git)

# ── PostgreSQL ──
POSTGRES_DB=gym_db
POSTGRES_USER=SportGym
POSTGRES_PASSWORD=cambiar_password_seguro

# ── Backend ──
SERVER_PORT=8080
JWT_SECRET=cambiar-clave-minimo-32-caracteres-aleatorios
JWT_EXPIRATION_MS=86400000

# Torniquete / lector ZKT / pantalla /acceso (misma clave en backend, frontend build y ZKT)
ACCESS_DEVICE_KEY=clave-torniquete-produccion-2026

# Relé o torniquete físico (vacío = solo registra ingreso, no abre puerta)
TURNSTILE_WEBHOOK=

# Rostro en /acceso si lo usas (opcional, default 0.55)
FACE_MATCH_MAX_DISTANCE=0.55

# Ventas F2 — pase día (opcional)
WORKOUT_DAY_CATEGORIES="ENTRENO_DIA,ENTRENO,Plan entreno"

# ── URLs públicas (mismo dominio con /api en nginx) ──
GYM_PUBLIC_URL=https://sportgymr10.com
GYM_API_PUBLIC_URL=https://sportgymr10.com
CORS_ORIGINS=https://sportgymr10.com

# ── Build frontend (docker build args) ──
API_URL=https://sportgymr10.com/api
UPLOADS_BASE_URL=https://sportgymr10.com
